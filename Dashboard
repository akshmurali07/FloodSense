<script>
// =====================
// DATA & LOGIC
// =====================
const socialData = [
  { text: "Water entering my house help!", lat: 17.3850, lon: 78.4867, id: 1 },
  { text: "Flood rising near main road urgent!", lat: 17.3865, lon: 78.4875, id: 2 },
  { text: "Minor water logging here", lat: 17.3880, lon: 78.4850, id: 3 }
];

let waterLevel = 7;
let markers = [];
let activityEntries = [];

const RISK_CONFIG = {
  CRITICAL: { color: '#ff1744', icon: '🚨', bg: 'rgba(255,23,68,0.12)', border: 'rgba(255,23,68,0.3)', bodyClass: 'risk-CRITICAL' },
  HIGH:     { color: '#ff7043', icon: '⚠️', bg: 'rgba(255,112,67,0.12)', border: 'rgba(255,112,67,0.3)', bodyClass: 'risk-HIGH' },
  MODERATE: { color: '#f5c518', icon: '🔶', bg: 'rgba(245,197,24,0.12)', border: 'rgba(245,197,24,0.3)', bodyClass: 'risk-MODERATE' },
  LOW:      { color: '#00e676', icon: '✅', bg: 'rgba(0,230,118,0.08)', border: 'rgba(0,230,118,0.2)', bodyClass: 'risk-LOW' }
};

const ALERT_MSGS = {
  CRITICAL: '🚨 CRITICAL ALERT — IMMEDIATE EVACUATION REQUIRED — ALL UNITS RESPOND',
  HIGH:     '⚠️  HIGH RISK DETECTED — EMERGENCY SERVICES ON STANDBY — EVACUATE LOW AREAS',
  MODERATE: '🔶 MODERATE FLOODING — STAY ALERT — AVOID FLOOD-PRONE ZONES',
  LOW:      '✅ SYSTEM NOMINAL — ALL ZONES MONITORED — WATER LEVELS STABLE'
};

const GAUGE_STATUS = {
  CRITICAL: 'EXTREME', HIGH: 'DANGER', MODERATE: 'ELEVATED', LOW: 'NORMAL'
};

function cleanText(t) { return t.toLowerCase().replace(/[^a-zA-Z\s]/g, ''); }

function calcTextRisk(t) {
  const words = ["help","trapped","drowning","urgent","emergency"];
  return words.reduce((s,w) => s + (t.includes(w) ? 2 : 0), 0);
}

function calcSensorRisk(lvl) {
  return lvl > 8 ? 5 : lvl > 5 ? 3 : 1;
}

function classifyZone(score) {
  return score >= 7 ? 'CRITICAL' : score >= 4 ? 'HIGH' : score >= 2 ? 'MODERATE' : 'LOW';
}

function getOverallRisk(zones) {
  if (zones.includes('CRITICAL')) return 'CRITICAL';
  if (zones.includes('HIGH')) return 'HIGH';
  if (zones.includes('MODERATE')) return 'MODERATE';
  return 'LOW';
}

// =====================
// MAP SETUP
// =====================
const map = L.map('map', { zoomControl: false, attributionControl: false })
  .setView([17.3865, 78.4867], 15);

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);
L.control.zoom({ position: 'bottomright' }).addTo(map);

function makeMarkerIcon(color, zone, score) {
  const isPulsing = zone === 'CRITICAL' || zone === 'HIGH';
  return L.divIcon({
    className: '',
    html: `
      <div style="position:relative; width:36px; height:36px;">
        ${isPulsing ? `<div style="
          position:absolute; inset:-6px; border-radius:50%;
          background:${color};
          opacity:0.2;
          animation:marker-pulse 1.5s ease-in-out infinite;
        "></div>` : ''}
        <div style="
          width:36px; height:36px; border-radius:50%;
          background: radial-gradient(circle at 35% 35%, ${color}cc, ${color}44);
          border: 2.5px solid ${color};
          box-shadow: 0 0 14px ${color}99;
          display:flex; align-items:center; justify-content:center;
          font-size:14px; font-weight:700;
          color:#fff;
          font-family:'Rajdhani',sans-serif;
          position:relative;
        ">${score}</div>
      </div>
      <style>@keyframes marker-pulse{0%,100%{transform:scale(1);opacity:0.2}50%{transform:scale(1.6);opacity:0}}</style>
    `,
    iconSize: [36, 36],
    iconAnchor: [18, 18],
    popupAnchor: [0, -20]
  });
}

// =====================
// MAIN RENDER
// =====================
function runAnalysis() {
  markers.forEach(m => map.removeLayer(m));
  markers = [];

  const sensorScore = calcSensorRisk(waterLevel);
  const zones = [];
  const counts = { CRITICAL: 0, HIGH: 0, MODERATE: 0, LOW: 0 };

  const cardContainer = document.getElementById('reportsList');
  cardContainer.innerHTML = '';

  socialData.forEach((post, i) => {
    const cleaned = cleanText(post.text);
    const textScore = calcTextRisk(cleaned);
    const total = textScore + sensorScore;
    const zone = classifyZone(total);
    const cfg = RISK_CONFIG[zone];
    zones.push(zone);
    counts[zone]++;

    // Marker
    const marker = L.marker([post.lat, post.lon], {
      icon: makeMarkerIcon(cfg.color, zone, total)
    }).addTo(map);

    marker.bindPopup(`
      <div style="font-family:'Rajdhani',sans-serif;">
        <div style="font-size:14px;font-weight:700;color:${cfg.color};letter-spacing:2px;margin-bottom:6px;">${cfg.icon} ${zone}</div>
        <div style="font-size:13px;margin-bottom:4px;">"${post.text}"</div>
        <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#3a6080;margin-bottom:3px;">
          SCORE: ${total} &nbsp;|&nbsp; SENSOR: ${waterLevel}m
        </div>
        <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#3a6080;">
          📍 ${post.lat.toFixed(4)}, ${post.lon.toFixed(4)}
        </div>
      </div>
    `);
    markers.push(marker);

    // Zone card
    const card = document.createElement('div');
    card.className = `report-card ${zone}`;
    card.style.animationDelay = `${i * 0.1}s`;
    card.innerHTML = `
      <div class="card-top">
        <span class="risk-tag">${zone}</span>
        <span class="card-score">${total}</span>
      </div>
      <div class="card-msg">"${post.text}"</div>
      <div class="card-coord">📍 ${post.lat.toFixed(4)}, ${post.lon.toFixed(4)}</div>
    `;
    card.onclick = () => {
      map.flyTo([post.lat, post.lon], 17, { duration: 1.2 });
      setTimeout(() => marker.openPopup(), 1300);
    };
    cardContainer.appendChild(card);
  });

  // Stats
  document.getElementById('sCrit').textContent = counts.CRITICAL;
  document.getElementById('sHigh').textContent = counts.HIGH;
  document.getElementById('sMod').textContent = counts.MODERATE;
  document.getElementById('sLow').textContent = counts.LOW;

  // Overall risk
  const overall = getOverallRisk(zones);
  applyRiskTheme(overall);

  // Log
  addLog(overall, `Sensor: ${waterLevel}m | Zones: C${counts.CRITICAL} H${counts.HIGH} M${counts.MODERATE} L${counts.LOW}`);
}

// =====================
// DYNAMIC THEME
// =====================
function applyRiskTheme(risk) {
  const cfg = RISK_CONFIG[risk];

  // Body class for CSS variable switching
  document.body.className = cfg.bodyClass;

  // Alert banner
  const banner = document.getElementById('alertBanner');
  banner.style.background = cfg.bg;
  banner.style.borderColor = cfg.border;
  banner.style.color = cfg.color;
  document.getElementById('alertText').textContent = ALERT_MSGS[risk];

  // App icon
  const icon = document.getElementById('appIcon');
  icon.style.borderColor = cfg.color;
  icon.style.boxShadow = `0 0 18px ${cfg.color}55`;
  icon.textContent = cfg.icon === '✅' ? '🌊' : cfg.icon;

  // Risk circle
  const circle = document.getElementById('riskCircle');
  circle.style.borderColor = cfg.color;
  circle.style.boxShadow = `0 0 30px ${cfg.color}33, inset 0 0 20px ${cfg.color}11`;
  document.getElementById('riskIcon').textContent =
    risk === 'CRITICAL' ? '🚨' : risk === 'HIGH' ? '⚠️' : risk === 'MODERATE' ? '🔶' : '💧';
  document.getElementById('riskLevelBig').textContent = risk;
  document.getElementById('riskLevelBig').style.color = cfg.color;

  // Gauge status
  const gs = document.getElementById('gaugeStatus');
  gs.textContent = GAUGE_STATUS[risk];
  gs.style.background = cfg.bg;
  gs.style.color = cfg.color;
  gs.style.border = `1px solid ${cfg.border}`;
}

// =====================
// SENSOR UPDATE
// =====================
function updateSensor(val) {
  waterLevel = parseFloat(val);
  document.getElementById('gaugeNum').innerHTML = `${waterLevel.toFixed(1)}<span>m</span>`;
  const pct = (waterLevel / 15) * 100;
  document.getElementById('gaugeFill').style.height = pct + '%';
  runAnalysis();
}

// =====================
// ACTIVITY LOG
// =====================
function addLog(risk, msg) {
  const now = new Date();
  const time = now.toTimeString().slice(0,8);
  const cfg = RISK_CONFIG[risk];
  const entry = { time, msg, color: cfg.color, risk };
  activityEntries.unshift(entry);
  if (activityEntries.length > 20) activityEntries.pop();
  renderLog();
}

function renderLog() {
  const log = document.getElementById('activityLog');
  log.innerHTML = activityEntries.map((e,i) => `
    <div class="log-entry" style="animation-delay:${i*0.05}s">
      <div class="log-dot" style="background:${e.color}"></div>
      <span class="log-time">${e.time}</span>
      <span class="log-msg">${e.msg}</span>
    </div>
  `).join('');
}

// =====================
// SIMULATE
// =====================
function simulateRandom() {
  const val = (Math.random() * 15).toFixed(1);
  document.getElementById('sensorSlider').value = val;
  updateSensor(val);
}

// =====================
// EXPORT
// =====================
function exportData() {
  const data = socialData.map(post => {
    const total = calcTextRisk(cleanText(post.text)) + calcSensorRisk(waterLevel);
    return { ...post, zone: classifyZone(total), score: total, sensorLevel: waterLevel };
  });
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `floodsense_export_${Date.now()}.json`;
  a.click();
  addLog('LOW', 'Data exported successfully');
}

// =====================
// CLOCK
// =====================
function updateClock() {
  document.getElementById('clock').textContent =
    new Date().toTimeString().slice(0,8);
}
setInterval(updateClock, 1000);
updateClock();

// =====================
// AUTO SIMULATE (every 8s)
// =====================
setInterval(() => {
  // Gentle drift simulation
  const drift = (Math.random() - 0.5) * 1.5;
  const newVal = Math.max(0, Math.min(15, waterLevel + drift));
  document.getElementById('sensorSlider').value = newVal;
  updateSensor(newVal);
}, 8000);

// =====================
// INIT
// =====================
runAnalysis();
</script>


